{
  "name": "relyce-book",
  "version": "1.0.1",
  "description": "Relyce Book - Indian GST Offline Billing System",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "build": "electron-builder",
    "build:secure": "node scripts/obfuscate.js && electron-builder"
  },
  "build": {
    "appId": "com.relyce.book",
    "productName": "Relyce Book",
    "win": {
      "target": "nsis",
      "icon": "assets/relyce_logo.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "afterPack": "./scripts/afterPack.js",
    "files": [
      {
        "from": "dist_obfuscated",
        "to": "."
      },
      "assets/**/*",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github"
      }
    ]
  },
  "keywords": [
    "billing",
    "gst",
    "invoice",
    "accounting",
    "india"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ukenthirana01/billing-software.git"
  },
  "author": "Relyce Book",
  "license": "MIT",
  "devDependencies": {
    "asarmor": "^3.0.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "javascript-obfuscator": "^5.4.1"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "bootstrap-icons": "^1.13.1",
    "chart.js": "^4.5.1",
    "electron-updater": "^6.8.3",
    "googleapis": "^140.0.1",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.1",
    "tesseract.js": "^4.1.4",
    "xlsx": "^0.18.5"
  }
}